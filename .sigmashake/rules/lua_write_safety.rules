# lua_write_safety.rules
# Technology: lua | Capability: write

rule lua-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "os.execute("
  MESSAGE "Blocked an unsafe pattern in lua. Use the recommended best practices for 2025/2026."
}

rule lua-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "module("
  MESSAGE "You are using an outdated API for lua. Please upgrade to the newer API."
}
